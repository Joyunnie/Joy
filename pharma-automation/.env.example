# === Database ===
POSTGRES_USER=pharma_user
POSTGRES_PASSWORD=          # 강력한 비밀번호: openssl rand -base64 24
POSTGRES_DB=pharma

# === Backend (PHARMA_ prefix → cloud/app/config.py Settings) ===
PHARMA_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
PHARMA_JWT_SECRET_KEY=      # 반드시 변경: openssl rand -hex 32
PHARMA_JWT_ALGORITHM=HS256
PHARMA_ACCESS_TOKEN_EXPIRE_MINUTES=30
PHARMA_REFRESH_TOKEN_EXPIRE_DAYS=7
PHARMA_OCR_ENGINE=google_vision
PHARMA_GOOGLE_VISION_API_KEY=
PHARMA_UPLOAD_DIR=/app/uploads/receipts
PHARMA_CORS_ORIGINS=https://yourdomain.com

# === HTTPS (Let's Encrypt) ===
LETSENCRYPT_EMAIL=
DOMAIN=                     # 예: pharma.example.com (IP 전용 시 비워두기)
