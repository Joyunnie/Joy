# Database password for PostgreSQL (used in docker-compose.yml)
POSTGRES_PASSWORD=changeme

# JWT secret key for token signing — generate with: openssl rand -hex 32
PHARMA_JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# Invite code required for user registration
PHARMA_INVITE_CODE=changeme

# Google Cloud Vision API key (optional — OCR endpoints return 503 if not set)
PHARMA_GOOGLE_VISION_API_KEY=your-api-key-here

# Test database URL (used by pytest; defaults to testpass if not set)
# PHARMA_TEST_DATABASE_URL=postgresql+asyncpg://pharma_user:YOUR_DB_PASSWORD@localhost:5432/pharma
